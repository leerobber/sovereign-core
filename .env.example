# Sovereign Core — Environment Variables
# Copy to .env and fill in your values

# ── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Optional API key — leave blank to disable auth
GATEWAY_API_KEY=

# CORS
GATEWAY_CORS_ORIGINS=*

GATEWAY_HEALTH_CHECK_INTERVAL=5
GATEWAY_BACKEND_TIMEOUT=30
GATEWAY_FAILURE_THRESHOLD=3
GATEWAY_RECOVERY_THRESHOLD=2
GATEWAY_LATENCY_EMA_ALPHA=0.2

# ── Backend URLs ──────────────────────────────────────────────────────────────
BACKEND_NVIDIA_URL=http://localhost:8001
BACKEND_AMD_URL=http://localhost:8002
BACKEND_CPU_URL=http://localhost:8003

# ── Model Assignments (your actual models as of 2026-04-17) ──────────────────
# RTX 5050 (NVIDIA 8GB) — heavy reasoning, complex proposals
MODEL_PRIMARY=gemma3:12b

# Radeon 780M (AMD 4GB) — code, critic, meta-agent
MODEL_SECONDARY=qwen2.5:7b

# Ryzen 7 CPU — fast fallback, light tasks
MODEL_FALLBACK=llama3.2:3b

# Embeddings — memory palace vector search (any backend)
MODEL_EMBED=nomic-embed-text:latest

# All available models on this machine:
# gemma3:12b        8.1GB  → RTX 5050 primary
# qwen2.5:7b        4.7GB  → Radeon 780M primary
# dolphin-llama3:8b 4.7GB  → RTX 5050 secondary (uncensored general)
# llama3:latest     4.7GB  → RTX 5050 tertiary
# dolphin-phi       1.6GB  → CPU fast tasks
# llama3.2:3b       2.0GB  → CPU fallback
# nomic-embed-text  274MB  → embeddings (any backend)

# ── KAIROS SAGE Loop Model Assignments ───────────────────────────────────────
KAIROS_PROPOSER_MODEL=gemma3:12b
KAIROS_PROPOSER_BACKEND=http://localhost:8001
KAIROS_CRITIC_MODEL=qwen2.5:7b
KAIROS_CRITIC_BACKEND=http://localhost:8002
KAIROS_VERIFIER_MODEL=gemma3:12b
KAIROS_VERIFIER_BACKEND=http://localhost:8001
KAIROS_META_MODEL=qwen2.5:7b
KAIROS_META_BACKEND=http://localhost:8002

# ── Memory Palace / Iron Dome ─────────────────────────────────────────────────
EMBED_BACKEND=http://localhost:8001
EMBED_MODEL=nomic-embed-text:latest

# ── Security ──────────────────────────────────────────────────────────────────
# Set this to a strong random string in production
SOVEREIGN_LICENSE_SECRET=

# HMAC secret for ledger integrity
GATEWAY_LEDGER_HMAC_SECRET=
