# ─────────────────────────────────────────────────────────────────────────────
# Sovereign Core Gateway — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Gateway ───────────────────────────────────────────────────────────────────
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8080

# ── Security ──────────────────────────────────────────────────────────────────
# Set this to require API key auth on all endpoints
# Leave blank for open access (development only)
GATEWAY_API_KEY=

# Secret for HMAC signing of ledger entries
GATEWAY_LEDGER_HMAC_SECRET=change-me-to-a-random-secret

# Rate limiting
GATEWAY_RATE_LIMIT_RPS=100
GATEWAY_RATE_LIMIT_BURST=20

# ── Backends ──────────────────────────────────────────────────────────────────
# Your local Ollama backends (started by sovereign_launch.py)
# RTX 5050 (NVIDIA 8GB) — gemma3:12b
OLLAMA_RTX_URL=http://localhost:8001

# Radeon 780M (AMD 4GB) — qwen2.5:7b
OLLAMA_RADEON_URL=http://localhost:8002

# Ryzen 7 CPU — llama3.2:3b
OLLAMA_CPU_URL=http://localhost:8003

# ── SAGE / KAIROS ─────────────────────────────────────────────────────────────
# Where other repos find the Sovereign Core gateway
SOVEREIGN_GATEWAY_URL=http://localhost:8080

# Directory for KAIROS agent archive files
KAIROS_AGENTS_DIR=data/kairos/agents

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite database path — all learning persists here
SOVEREIGN_DB_PATH=data/sovereign.db

# ── Health monitoring ─────────────────────────────────────────────────────────
GATEWAY_HEALTH_CHECK_INTERVAL=5.0
GATEWAY_BACKEND_TIMEOUT=30.0
GATEWAY_FAILURE_THRESHOLD=3
GATEWAY_RECOVERY_THRESHOLD=2

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins (defaults to localhost variants)
# GATEWAY_CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
