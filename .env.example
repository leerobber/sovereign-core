# Sovereign Core — Environment Variables
# Copy to .env and fill in your values

# ── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Optional API key — set to protect all endpoints (except /health, /metrics)
# Leave blank to disable auth
GATEWAY_API_KEY=

# CORS — comma-separated allowed origins (* for all)
GATEWAY_CORS_ORIGINS=*

# Backend health check settings
GATEWAY_HEALTH_CHECK_INTERVAL=5
GATEWAY_BACKEND_TIMEOUT=30
GATEWAY_FAILURE_THRESHOLD=3
GATEWAY_RECOVERY_THRESHOLD=2
GATEWAY_LATENCY_EMA_ALPHA=0.2

# ── Backend URLs ──────────────────────────────────────────────────────────────
# Override if backends are on different machines
BACKEND_NVIDIA_URL=http://localhost:8001
BACKEND_AMD_URL=http://localhost:8002
BACKEND_CPU_URL=http://localhost:8003

# ── ChromaDB (vector store) ───────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8004

# ── KAIROS ────────────────────────────────────────────────────────────────────
# Directory to persist KAIROS agent state
KAIROS_AGENTS_DIR=data/kairos/agents

# Max ARSO cycles per evolution run
KAIROS_MAX_CYCLES=50

# ── Observability ─────────────────────────────────────────────────────────────
# Grafana admin password (docker compose only)
GRAFANA_PASSWORD=sovereign

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Aegis-Vault Ledger ────────────────────────────────────────────────────────
# HMAC secret for ledger integrity tags — CHANGE THIS in production
LEDGER_HMAC_SECRET=change-me-in-production

# Max entries to keep in memory before flushing to disk
LEDGER_MAX_MEMORY_ENTRIES=10000

# ── MemEvolve ─────────────────────────────────────────────────────────────────
# A/B test split ratio (0.0-1.0 — fraction using evolved strategy)
MEM_EVOLVE_AB_RATIO=0.5
